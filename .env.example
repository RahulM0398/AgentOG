# Copy to `.env.local` and Vercel. Never commit real secrets.

# Public URL — production demo:
# APP_BASE_URL=https://agent-og.vercel.app
# NEXT_PUBLIC_APP_URL=https://agent-og.vercel.app
# Local dev:
APP_BASE_URL=
NEXT_PUBLIC_APP_URL=http://localhost:3000

MOCK_INTEGRATIONS=false
ALLOW_DEMO_ENDPOINTS=false

# AgentOG core
AGENTOG_SIGNING_SECRET=
# Legacy alias supported in code:
AGENT_OG_JWT_SECRET=
AGENTOG_APPROVAL_TOKEN_TTL_MINUTES=10
AGENT_OG_APPROVAL_TTL_SECONDS=600

# Gemini / Gemma (either GEMINI_API_KEY or GOOGLE_GENERATIVE_AI_API_KEY)
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_PLANNER_MODEL=gemini-2.0-flash
GEMINI_CLASSIFIER_MODEL=gemini-2.0-flash
GEMMA_MODEL=

# Browser Use
BROWSER_USE_API_KEY=
BROWSER_USE_DISABLED=false

# Moss
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_POLICY_INDEX=agentog-policies
# Moss Control Plane HTTPS (no native SDK — safe on Vercel)
MOSS_MANAGE_URL=https://service.usemoss.dev/v1/manage

# Supermemory
SUPERMEMORY_API_BASE_URL=https://api.supermemory.ai
SUPERMEMORY_API_KEY=
SUPERMEMORY_USER_CONTAINER=user_001

# AgentMail
AGENTMAIL_API_BASE_URL=https://api.agentmail.to
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
AGENTMAIL_FROM=

# AgentPhone
AGENTPHONE_API_BASE_URL=https://api.agentphone.ai
AGENTPHONE_API_KEY=
AGENTPHONE_AGENT_ID=
AGENTPHONE_NUMBER_ID=
AGENTPHONE_WEBHOOK_SECRET=
AGENTPHONE_FROM_NUMBER=

# Demo contacts
DEMO_USER_NAME=Alex
GUARDIAN_NAME=Rahul
GUARDIAN_EMAIL=
GUARDIAN_PHONE=
AGENT_OG_APPROVER_EMAIL=
AGENT_OG_APPROVER_PHONE=

# Stripe (test mode)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SIMULATED=true

# Optional: Supabase for durable storage (when unset, in-memory store is used)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
